{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Only",
            "type": "shell",
            "command": "cmake --build ${workspaceFolder}/build/Debug",
            "problemMatcher": "$gcc",
            "group": "build"
        },
        {
            "label": "Build & Flash",
            "type": "shell",
            "command": "openocd",
            "args": [
                "-f", "interface/cmsis-dap.cfg",
                "-f", "target/stm32g4x.cfg",
                "-c", "program ${workspaceFolder}/build/Debug/${workspaceFolderBasename}.elf verify reset exit"
            ],
            "dependsOn": "Build Only",
            "group": {
                "kind": "build",
                "isDefault": true 
            },
            "problemMatcher": []
            
        },
        {
            "label": "Unlock Flash",
            "type": "shell",
            "command": "openocd",
            "args": [
                "-f", "interface/cmsis-dap.cfg",
                "-f", "target/stm32g4x.cfg",
                "-c", "init; reset halt; stm32g4x unlock 0; reset halt; exit"
            ],
            "problemMatcher": []
        }
    ]
}